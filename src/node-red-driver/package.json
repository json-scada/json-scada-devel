{
  "name": "node-red-driver",
  "version": "0.1.0",
  "description": "{json:scada} - Node-RED bidirectional integration driver (NODE-RED). Hosts a WebSocket JSON server for Node-RED flows.",
  "type": "module",
  "main": "dist/main.js",
  "config": {
    "envPrefix": "JS_NODERED_"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "bin": {
    "node-red-driver": "dist/main.js"
  },
  "author": "Ricardo Lastra Olsen",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "mongodb": "^7.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
